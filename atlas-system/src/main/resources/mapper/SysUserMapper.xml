<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.bubua12.atlas.system.mapper.SysUserMapper">

    <select id="pageUser" resultType="com.bubua12.atlas.system.repository.SysUser">
        SELECT u.*
        FROM sys_user u
        WHERE u.deleted = 0
        <if test="username != null and username != ''">
            AND u.username LIKE CONCAT('%', #{username}, '%')
        </if>
        ORDER BY u.create_time DESC
    </select>

    <!-- 删除用户已绑定的角色 -->
    <delete id="deleteUserRoles">
        DELETE
        FROM sys_user_role
        WHERE user_id = #{userId}
    </delete>

    <!-- 给用户绑定角色 -->
    <insert id="insertUserRoles">
        INSERT INTO sys_user_role (user_id, role_id) VALUES
        <foreach collection="roleIds" item="roleId" separator=",">
            (#{userId}, #{roleId})
        </foreach>
    </insert>

    <!-- 获取用户的角色ID列表 -->
    <select id="selectRoleIdsByUserId" resultType="java.lang.Long">
        SELECT role_id
        FROM sys_user_role
        WHERE user_id = #{userId}
    </select>

    <!-- fixme 多表查询 获取用户的数据权限 -->
    <select id="selectUserDataScope" resultType="java.lang.Integer">
        SELECT MIN(r.data_scope)
        FROM sys_role r
                 INNER JOIN sys_user_role ur ON r.role_id = ur.role_id
        WHERE ur.user_id = #{userId}
          AND r.deleted = 0
          AND r.status = 0
    </select>

</mapper>
